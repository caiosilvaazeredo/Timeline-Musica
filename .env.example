# URL publica do app (obrigatoria em producao, usada no QR code e no OAuth)
BASE_URL=https://hitster-digital.onrender.com

# Opcional: dominio curto de entrada dos jogadores (modelo kahoot.it)
# Aponte um custom domain do Render para o mesmo servico e informe aqui
JOIN_URL=

# Spotify (opcional): necessario apenas para a fonte SPOTIFY
# Crie um app em https://developer.spotify.com/dashboard e cadastre o Redirect URI:
#   {BASE_URL}/auth/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube (opcional): necessario apenas para a fonte YOUTUBE
# Crie uma chave da YouTube Data API v3 em https://console.cloud.google.com
YT_API_KEY=

# Porta local (o Render define PORT automaticamente)
PORT=3000
